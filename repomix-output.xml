  const query = searchQuery.value.toLowerCase()
  return allStreams.value.filter(stream => 
    stream.title.toLowerCase().includes(query) || 
    stream.host.toLowerCase().includes(query) ||
    stream.category.toLowerCase().includes(query)
  )
})
