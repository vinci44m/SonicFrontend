    const data = await response.json()

    if (!response.ok) {
      errorMessage.value = data.error || 'Login fehlgeschlagen.'
      return
    }

    alert('Erfolg! Du bist eingeloggt.')
    router.push('/') // Zurück zur Startseite

  } catch (error) {
    errorMessage.value = 'Server nicht erreichbar.'
  }
}
