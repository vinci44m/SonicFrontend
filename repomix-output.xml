/* =====================
   THEME STYLES (Light/Dark Mode)
   ===================== */
:root {
  /* Standardmäßig Dark Mode */
  --bg-color: #060f1a;
  --header-bg: #0d1b2a;
  --sidebar-bg: #060f1a;
  --card-bg: #0f172a;
  --text-color: #e0e0e0;
  --text-title: #ffffff;
  --text-muted: #64748b;
  --primary-color: #1e90ff;
  --border-color: #1a3a5c;
}

[data-theme="light"] {
  /* Hellen Farben */
  --bg-color: #f4f7fa;
  --header-bg: #ffffff;
  --sidebar-bg: #ffffff;
  --card-bg: #ffffff;
  --text-color: #1e293b;
  --text-title: #0f172a;
  --text-muted: #64748b;
  --primary-color: #0070f3;
  --border-color: #e2e8f0;
}

/* Euer bestehender Code nutzt nun diese Variablen */
body {
  background-color: var(--bg-color);
  color: var(--text-color);
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  transition: background-color 0.3s, color 0.3s;
}

header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 24px;
  background-color: var(--header-bg);
  border-bottom: 2px solid var(--primary-color);
  transition: background-color 0.3s;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background-color: #060f1a;
  color: #e0e0e0;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

/* =====================
   HEADER
   ===================== */
header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 24px;
  background-color: #0d1b2a;
  border-bottom: 2px solid #1e90ff;
}

header h1 {
  font-size: 26px;
  font-weight: 900;
  letter-spacing: 5px;
  color: #1e90ff;
}

header a {
  text-decoration: none;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.login-btn,
.upload-btn {
  padding: 8px 22px;
  background-color: transparent;
  border: 2px solid #1e90ff;
  border-radius: 8px;
  color: #1e90ff;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 1px;
  cursor: pointer;
  text-decoration: none;
  transition: background-color 0.2s, color 0.2s;
}

.login-btn:hover,
.upload-btn:hover {
  background-color: #1e90ff;
  color: #0d1b2a;
}

/* Styling für das Upload-Dropdown */
.upload-dropdown-container {
  position: relative;
  display: inline-block;
}

.upload-dropdown-menu {
  position: absolute;
  top: 100%;
  right: 0;
  margin-top: 8px;
  background-color: var(--card-bg, #0f172a);
  border: 2px solid var(--primary-color, #1e90ff);
  border-radius: 8px;
  min-width: 180px;
  box-shadow: 0 px 10px rgba(0, 0, 0, 0.3);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.upload-dropdown-menu a {
  color: var(--text-color, #e0e0e0);
  padding: 12px 16px;
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
  text-align: left;
  transition: background-color 0.2s;
}

.upload-dropdown-menu a:hover {
  background-color: rgba(30, 144, 255, 0.15);
  color: var(--primary-color, #1e90ff);
}

/* =====================
   SEARCH BAR
   ===================== */
.search-bar {
  display: flex;
  align-items: center;
  flex: 1;
  max-width: 480px;
  margin: 0 24px;
  background-color: #0a1829;
  border: 1px solid #1a3a5c;
  border-radius: 8px;
  overflow: hidden;
  transition: border-color 0.2s;
}

.search-bar:focus-within {
  border-color: #1e90ff;
}

.search-bar input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  padding: 9px 14px;
  color: #dce9f5;
  font-size: 14px;
}

.search-bar input::placeholder {
  color: #3d6a8a;
}

.search-bar button {
  background: #1e90ff;
  border: none;
  padding: 9px 16px;
  cursor: pointer;
  color: #060f1a;
  font-size: 16px;
  transition: background-color 0.2s;
  width: auto;
  margin-top: 0;
