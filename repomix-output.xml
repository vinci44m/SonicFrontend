<script setup>
import { ref } from 'vue'

const title = ref('')
const videoFile = ref(null)
const message = ref('')

const handleFileUpload = (event) => {
  videoFile.value = event.target.files[0]
}

const uploadVideo = async () => {
  if (!title.value || !videoFile.value) {
    message.value = 'Bitte Titel und Datei auswählen!'
    return
  }

  const formData = new FormData()
  formData.append('title', title.value)
  formData.append('video', videoFile.value)

  try {
    const response = await fetch('https://sonicbackend-production.up.railway.app/api/videos', {
      method: 'POST',
      body: formData,
    })

    if (response.ok) {
      message.value = 'Erfolg! Das Video wurde hochgeladen.'
      title.value = ''
    } else {
      message.value = 'Fehler beim Hochladen.'
    }
  } catch (error) {
    message.value = 'Verbindungsfehler.'
    console.error(error)
  }
}
</script>

